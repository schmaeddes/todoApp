{
  "name": "todo-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dev:linux": "cross-env ELECTRON_LINUX_SAFE=1 npm run dev",
    "start": "npm run build:ui && cross-env ELECTRON_USE_DIST=1 electron .",
    "start:linux": "npm run build:ui && cross-env ELECTRON_LINUX_SAFE=1 ELECTRON_USE_DIST=1 electron .",
    "build": "npm run build:icons && npm run build:ui && electron-builder",
    "build:linux": "npm run build:icons && npm run build:ui && electron-builder --linux AppImage",
    "build:win": "npm run build:icons && npm run build:ui && electron-builder --win portable",
    "build:mac": "npm run build:icons && npm run build:ui && electron-builder --mac dmg",
    "build:ui": "cross-env ELECTRON=1 vite build",
    "build:icons": "node scripts/generate-icon.mjs",
    "dev:web": "concurrently \"node server/index.js\" \"vite\"",
    "start:web": "cross-env NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "express": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.2.0",
    "cross-env": "^7.0.3",
    "electron": "^35.1.5",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.todo-app.desktop",
    "productName": "Todo App",
    "directories": {
      "output": "release"
    },
    "artifactName": "${name}-${version}.${ext}",
    "icon": "build/icon.png",
    "afterPack": "electron/after-pack.cjs",
    "afterAllArtifactBuild": "electron/after-all-artifact-build.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Office",
      "executableName": "todo-app"
    },
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    }
  }
}
